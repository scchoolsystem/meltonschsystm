{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "SmartDev",
    "version": "0.1.0",
    "identifier": "ke.co.smartdev.app",
    "build": {
        "frontendDist": "../dist/client",
        "devUrl": "https://smartdev.co.ke",
        "beforeDevCommand": "",
        "beforeBuildCommand": ""
    },
    "app": {
        "windows": [
            {
                "title": "SmartDev",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "android": {
            "debugApplicationIdSuffix": ".debug"
        }
    }
}
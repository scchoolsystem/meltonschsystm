{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "SmartDev",
    "version": "1.0.0",
    "identifier": "ke.co.smartdev",
    "build": {
        "frontendDist": "../dist/client",
        "devUrl": "https://smartdev.co.ke",
        "beforeDevCommand": "",
        "beforeBuildCommand": "pnpm build"
    },
    "app": {
        "windows": [
            {
                "title": "SmartDev ERP",
                "width": 1280,
                "height": 800,
                "minWidth": 1024,
                "minHeight": 640,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        },
        "updater": {
            "active": false
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [],
        "externalBin": [],
        "copyright": "© 2026 SmartDev",
        "category": "Education",
        "shortDescription": "School Management ERP",
        "longDescription": "SmartDev ERP - Multi-tenant school management platform for Kenyan schools"
    }
}

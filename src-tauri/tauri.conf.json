{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartDev",
  "version": "1.4.4",
  "identifier": "ke.co.smartdev",
  "build": {
    "frontendDist": "../dist-desktop",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "pnpm desktop:frontend",
    "beforeBuildCommand": "pnpm desktop:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SmartDev ERP",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://app.smartdev.co.ke https://*.smartdev.co.ke; connect-src 'self' https://app.smartdev.co.ke https://*.smartdev.co.ke https://vpikrrytxeyybfhnozyt.supabase.co wss://vpikrrytxeyybfhnozyt.supabase.co https://*.supabase.co wss://*.supabase.co https://api.safaricom.co.ke https://sandbox.safaricom.co.ke; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "SmartDev",
    "copyright": "2025 SmartDev",
    "category": "Business",
    "shortDescription": "School Management ERP",
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
